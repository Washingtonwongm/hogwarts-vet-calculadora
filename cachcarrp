<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Calculadora Golden MiniBits</title>

<style>

body{
    font-family: Arial, sans-serif;
    background:#f5f5f5;
    margin:0;
    padding:15px;
}

.tarjeta{
    max-width:500px;
    margin:auto;
    background:white;
    padding:25px;
    border-radius:15px;
    box-shadow:0 4px 15px rgba(0,0,0,.1);
    text-align:center;
}

h2{
    color:#2e7d32;
    font-size:20px;
    margin-top:0;
    margin-bottom:10px;
    font-weight:bold;
}

p{
    color:#555;
    margin-bottom:15px;
}

input{
    width:100%;
    padding:12px;
    font-size:18px;
    border:1px solid #ccc;
    border-radius:8px;
    box-sizing:border-box;
}

button{
    width:100%;
    margin-top:15px;
    padding:12px;
    font-size:18px;
    border:none;
    border-radius:8px;
    background:#2e7d32;
    color:white;
    cursor:pointer;
}

button:hover{
    opacity:.9;
}

#resultado{
    margin-top:20px;
    font-size:15px;
    line-height:1.5;
    text-align:left;
}

</style>
</head>

<body>

<div class="tarjeta">

<h2>Calcula su porción ideal</h2>

<p>Ingrese el peso de su mascota (kg)</p>

<input
type="number"
id="peso"
step="0.1"
min="0.5"
max="16"
placeholder="Ejemplo: 5">

<button onclick="calcular()">
Calcular
</button>

<div id="resultado"></div>

</div>

<script>

function calcular(){

    let peso = parseFloat(document.getElementById("peso").value);

    if(isNaN(peso) || peso < 0.5 || peso > 16){

        document.getElementById("resultado").innerHTML =
        "⚠️ Ingrese un peso entre 0.5 y 16 kg.";

        return;
    }

    let gramos = peso * 50;

    let dias3kg = 3000 / gramos;

    let dias15kg = 15000 / gramos;

    document.getElementById("resultado").innerHTML =
        "<strong>Recomendación Nutricional:</strong><br>" +

        "🐾 Peso: <strong>" +
        peso.toFixed(1) +
        " kg</strong><br>" +

        "🍖 Cantidad diaria recomendada: <strong>" +
        gramos.toFixed(0) +
        " g/día</strong><br>" +

        "📦 Una bolsa de 3kg durará aproximadamente <strong>" +
        dias3kg.toFixed(0) +
        " días</strong><br>" +

        "📦 Un saco de 15kg durará aproximadamente <strong>" +
        dias15kg.toFixed(0) +
        " días</strong>";
}

</script>

</body>
</html>
